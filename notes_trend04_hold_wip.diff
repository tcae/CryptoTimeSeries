+    startix = Ohlcv.rowix(trd.df[!, :opentime], startdt)
+    enddt = Ohlcv.dataframe(trd.ohlcv)[end, :opentime]
+    endix = Ohlcv.rowix(trd.df[!, :opentime], enddt)
